---
const { pathname } = Astro.url;
const isHome = pathname === '/' || pathname === '/blog' || pathname === '/blog/';
const isTags = pathname.startsWith('/tags');
---

<header class="site-hdr">
	<nav class="hdr-tinynav" aria-label="Site">
		<a href="/" class:list={[isHome && 'is-active']}>
			<span class="dot dot-pink" aria-hidden="true"></span>
			<span class="hdr-wordmark">Puzzm<em>o</em><span class="blog">· blog</span></span>
		</a>
		<a href="/tags/" class:list={[isTags && 'is-active']}>tags</a>
		<a href="/rss.xml">rss</a>
		<span class="hdr-spacer"></span>
		<a class="hdr-back" href="https://www.puzzmo.com/">→ play at puzzmo.com</a>
	</nav>
</header>
