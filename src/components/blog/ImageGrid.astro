---
interface Props {
	image1Src: string;
	image1Alt: string;
	image1Caption: string;
	image2Src: string;
	image2Alt: string;
	image2Caption: string;
}

const { image1Src, image1Alt, image1Caption, image2Src, image2Alt, image2Caption } = Astro.props;
---

<div class="image-grid">
	<div class="image-grid-item">
		<p style="text-align:center;font-size:0.9em;color:#666;">{image1Caption}</p>
		<img src={image1Src} alt={image1Alt} style="margin-top:0;width:100%;height:auto;" />
	</div>
	<div class="image-grid-item">
		<p style="text-align:center;font-size:0.9em;color:#666;">{image2Caption}</p>
		<img src={image2Src} alt={image2Alt} style="margin-top:0;width:100%;height:auto;" />
	</div>
</div>

<style>
	.image-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem;
		margin: 0.5rem -2rem;
	}
	.image-grid-item {
		display: flex;
		flex-direction: column;
	}
	@media (max-width: 768px) {
		.image-grid {
			grid-template-columns: 1fr !important;
		}
	}
</style>
