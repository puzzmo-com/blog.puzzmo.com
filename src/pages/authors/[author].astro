---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { AUTHORS, SITE_TITLE } from '../../consts';
import { getPublishedPosts, postUrl } from '../../lib/posts';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const authorSlugs = new Set<string>();
	for (const post of posts) {
		for (const author of post.data.authors ?? []) {
			authorSlugs.add(author);
		}
	}
	return [...authorSlugs].map((slug) => ({
		params: { author: slug },
		props: {
			slug,
			author: AUTHORS[slug] ?? { name: slug, bio: '' },
			posts: posts.filter((p) => p.data.authors?.includes(slug)),
		},
	}));
}

const { slug, author, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${author.name} - ${SITE_TITLE}`} description={author.bio} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{author.name}</h1>
			<p class="bio">{author.bio}</p>
			{author.twitter && <p><a href={`https://twitter.com/${author.twitter}`}>@{author.twitter}</a></p>}
			<h2>Posts</h2>
			<ul class="post-list">
				{posts.map((post: any) => (
					<li>
						<a href={postUrl(post)}>
							<span class="title">{post.data.title}</span>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
		<style>
			.bio {
				color: rgb(var(--gray));
				font-style: italic;
			}
			.post-list {
				list-style: none;
				padding: 0;
			}
			.post-list li {
				margin-bottom: 0.5rem;
			}
			.post-list a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				text-decoration: none;
				padding: 0.5rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list a:hover .title {
				color: rgb(var(--accent));
			}
			.date {
				color: rgb(var(--gray));
				font-size: 0.875rem;
				white-space: nowrap;
			}
		</style>
	</body>
</html>
