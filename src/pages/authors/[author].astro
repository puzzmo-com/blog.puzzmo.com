---
import AuthorAvatar from '../../components/AuthorAvatar.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostList from '../../components/PostList.astro';
import { SITE_TITLE } from '../../consts';
import { getAuthor } from '../../lib/authors';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const authorSlugs = new Set<string>();
	for (const post of posts) {
		for (const author of post.data.authors ?? []) {
			authorSlugs.add(author);
		}
	}
	return [...authorSlugs].map((slug) => ({
		params: { author: slug },
		props: {
			slug,
			posts: posts.filter((p) => p.data.authors?.includes(slug)),
		},
	}));
}

const { slug, posts } = Astro.props;
const author = await getAuthor(slug);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${author.name} — ${SITE_TITLE}`} description={author.bio} />
	</head>
	<body>
		<div class="page">
			<Header />
			<main class="idx">
				<header class="idx-pagehead">
					<p class="eyebrow">author</p>
					<div class="author-card">
						<AuthorAvatar author={author} size={56} />
						<div>
							<h1 style="margin: 0 0 4px;">{author.name}</h1>
							{author.bio && <p class="bio" style="margin: 0;">{author.bio}</p>}
						</div>
					</div>
					{(author.blueskyURL || author.twitch) && (
						<p class="links">
							{author.blueskyURL && (
								<a href={author.blueskyURL} target="_blank" rel="noopener">@{author.bsky} on bluesky</a>
							)}
							{author.blueskyURL && author.twitch && ' · '}
							{author.twitch && (
								<a href={`https://twitch.tv/${author.twitch}`} target="_blank" rel="noopener">{author.twitch} on twitch</a>
							)}
						</p>
					)}
					{(author.followersCount !== undefined || author.highlightedStats?.length) && (
						<div class="author-stats">
							{author.followersCount !== undefined && (
								<div class="stat">
									<span class="num">{author.followersCount.toLocaleString()}</span>
									<span class="label">followers</span>
								</div>
							)}
							{author.followingCount !== undefined && (
								<div class="stat">
									<span class="num">{author.followingCount.toLocaleString()}</span>
									<span class="label">following</span>
								</div>
							)}
							{author.highlightedStats?.map((stat) => (
								<div class="stat">
									<span class="num">{stat.msg}</span>
									<span class="label">{stat.section}</span>
								</div>
							))}
						</div>
					)}
				</header>
				<PostList posts={posts} emptyMessage="No posts yet." />
			</main>
			<Footer />
		</div>
	</body>
</html>
